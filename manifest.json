{
  "manifest_version": 3,
  "name": "NativeCamp Lesson Tracker",
  "version": "1.0",
  "description": "ネイティブキャンプのレッスン履歴を収集・分析します",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://nativecamp.net/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
